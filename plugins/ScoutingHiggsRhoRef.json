namespace {
  constexpr float M_PI_CH = 0.13957039f;
  constexpr float M_RHO   = 0.77526f;
  constexpr float M_H     = 125.0f;

  inline float toF(double x) { return static_cast<float>(x); }
  inline float toF(float  x) { return x; }
  inline float toF(int    x) { return static_cast<float>(x); }

  inline void setP4_massless(TLorentzVector& v, float pt, float eta, float phi) { v.SetPtEtaPhiM(pt, eta, phi, 0.0); }
  inline void setP4_pion(TLorentzVector& v, float pt, float eta, float phi)     { v.SetPtEtaPhiM(pt, eta, phi, M_PI_CH); }

  inline bool passAbsEta(float eta, float maxAbsEta) { return (maxAbsEta <= 0.f) ? true : (std::abs(eta) < maxAbsEta); }

  struct SimpleCand {
    float pt{0.f}, eta{0.f}, phi{0.f}, mass{0.f};
    int charge{0}; // 0 for neutral
  };

  struct RhoCand {
    SimpleCand piPlus;
    SimpleCand piMinus;
    TLorentzVector p4;
    float mass{ -1.f };
    float pt()  const { return toF(p4.Pt()); }
    float eta() const { return toF(p4.Eta()); }
    float phi() const { return toF(p4.Phi()); }
  };

  struct HCand {
    SimpleCand gamma;
    RhoCand rho;
    TLorentzVector p4;
    float mass{ -1.f };
    float pt()  const { return toF(p4.Pt()); }
    float eta() const { return toF(p4.Eta()); }
    float phi() const { return toF(p4.Phi()); }
  };

  // A clean bounded DFS on reco::Candidate mother pointers.
  inline bool hasAncestorPdgIdAbs(const reco::Candidate* start, int absPdgId, int guardMax = 300) {
    if (!start) return false;
    std::vector<const reco::Candidate*> stack;
    stack.reserve(32);
    const size_t nm0 = start->numberOfMothers();
    for (size_t i = 0; i < nm0; ++i) {
      const reco::Candidate* m = start->mother(i);
      if (m) stack.push_back(m);
    }
    int guard = 0;
    while (!stack.empty() && guard++ < guardMax) {
      const reco::Candidate* cur = stack.back();
      stack.pop_back();
      if (!cur) continue;
      if (std::abs(cur->pdgId()) == absPdgId) return true;
      const size_t nm = cur->numberOfMothers();
      for (size_t i = 0; i < nm; ++i) {
        const reco::Candidate* mm = cur->mother(i);
        if (mm) stack.push_back(mm);
      }
    }
    return false;
  }

  // ----------------------------
  // PF kinematics policy
  // ----------------------------
  inline bool pf_canUseTrkKinematics(const Run3ScoutingParticle& p, bool wantUseTrkVars) {
    if (!wantUseTrkVars) return false;
    return !p.relative_trk_vars();
  }
  inline float pf_pt(const Run3ScoutingParticle& p, bool wantUseTrkVars)  { return pf_canUseTrkKinematics(p, wantUseTrkVars) ? toF(p.trk_pt())  : toF(p.pt()); }
  inline float pf_eta(const Run3ScoutingParticle& p, bool wantUseTrkVars) { return pf_canUseTrkKinematics(p, wantUseTrkVars) ? toF(p.trk_eta()) : toF(p.eta()); }
  inline float pf_phi(const Run3ScoutingParticle& p, bool wantUseTrkVars) { return pf_canUseTrkKinematics(p, wantUseTrkVars) ? toF(p.trk_phi()) : toF(p.phi()); }

  inline float deltaR2(float eta1, float phi1, float eta2, float phi2) {
    const float dEta = eta1 - eta2;
    float dPhi = std::fabs(phi1 - phi2);
    if (dPhi > float(M_PI)) dPhi = float(2.0*M_PI) - dPhi;
    return dEta*dEta + dPhi*dPhi;
  }

  inline float absDeltaPhi(float phi1, float phi2) {
    float dphi = std::fabs(phi1 - phi2);
    if (dphi > float(M_PI)) dphi = float(2.0*M_PI) - dphi;
    return dphi;
  }

  // Choose best OS pion pair closest to rho mass.
  inline bool bestPionPairToRho(const std::vector<SimpleCand>& pions, SimpleCand& piPlus, SimpleCand& piMinus, RhoCand& rhoOut) {
    float bestDiff = std::numeric_limits<float>::infinity();
    bool found = false;
    TLorentzVector best; float bestMass = -1.f;
    SimpleCand bestP{}, bestM{};
    for (size_t i = 0; i < pions.size(); ++i) {
      for (size_t j = i + 1; j < pions.size(); ++j) {
        const auto& a = pions[i];
        const auto& b = pions[j];
        if (a.charge * b.charge >= 0) continue;
        TLorentzVector va, vb;
        setP4_pion(va, a.pt, a.eta, a.phi);
        setP4_pion(vb, b.pt, b.eta, b.phi);
        TLorentzVector v = va + vb;
        const float m = toF(v.M());
        const float diff = std::abs(m - M_RHO);
        if (diff < bestDiff) {
          bestDiff = diff; best = v; bestMass = m; found = true;
          if (a.charge > 0) { bestP = a; bestM = b; } else { bestP = b; bestM = a; }
        }
      }
    }
    if (!found) return false;
    piPlus = bestP; piMinus = bestM;
    rhoOut.piPlus = bestP; rhoOut.piMinus = bestM; rhoOut.p4 = best; rhoOut.mass = bestMass;
    return true;
  }

  // ----------------------------
  // Histogram packs
  // ----------------------------
  struct GenHistPack {
    TH1F* h_H_pt{nullptr}; TH1F* h_H_eta{nullptr};
    TH1F* h_g_pt{nullptr}; TH1F* h_g_eta{nullptr};
    TH1F* h_pi_pt{nullptr}; TH1F* h_pi_eta{nullptr}; TH1F* h_n_pi{nullptr};
    TH1F* h_rho_m{nullptr}; TH1F* h_rho_pt{nullptr}; TH1F* h_dr_pi_pi{nullptr};
    TH1F* h_dr_g_rho{nullptr}; TH1F* h_ptbal_rho_g{nullptr};
    TH1F* h_hcand_m{nullptr}; TH1F* h_hcand_pt{nullptr};
    TH2F* h_rho_m_vs_pt{nullptr}; TH2F* h_hcand_m_vs_pt{nullptr};

    void book(TFileDirectory& dir, const std::string& label) {
      h_H_pt  = dir.make<TH1F>(("H_pt_"+label).c_str(),  "GEN Higgs p_{T};p_{T} [GeV];events", 200, 0., 400.);
      h_H_eta = dir.make<TH1F>(("H_eta_"+label).c_str(), "GEN Higgs #eta;#eta;events",         120, -6., 6.);
      h_g_pt  = dir.make<TH1F>(("g_pt_"+label).c_str(),  "GEN #gamma p_{T};p_{T} [GeV];events", 200, 0., 400.);
      h_g_eta = dir.make<TH1F>(("g_eta_"+label).c_str(), "GEN #gamma #eta;#eta;events",         120, -6., 6.);
      h_pi_pt  = dir.make<TH1F>(("pi_pt_"+label).c_str(),  "GEN #pi^{#pm} p_{T};p_{T} [GeV];cands", 200, 0., 100.);
      h_pi_eta = dir.make<TH1F>(("pi_eta_"+label).c_str(), "GEN #pi^{#pm} #eta;#eta;cands",         120, -6., 6.);
      h_n_pi   = dir.make<TH1F>(("n_pi_"+label).c_str(),   "N_{#pi^{#pm}} candidates;N;cands",       60, -0.5, 59.5);
      h_rho_m   = dir.make<TH1F>(("rho_m_"+label).c_str(),   "GEN m(#pi#pi) (best OS);m [GeV];events", 200, 0., 2.0);
      h_rho_pt  = dir.make<TH1F>(("rho_pt_"+label).c_str(),  "GEN #rho cand p_{T};p_{T} [GeV];events", 200, 0., 250.);
      h_dr_pi_pi = dir.make<TH1F>(("dr_pi_pi_"+label).c_str(), "GEN #DeltaR(#pi,#pi);#DeltaR;events", 120, 0., 6.0);
      h_dr_g_rho   = dir.make<TH1F>(("dr_g_rho_"+label).c_str(),   "GEN #DeltaR(#gamma,#rho);#DeltaR;events", 120, 0., 6.0);
      h_ptbal_rho_g = dir.make<TH1F>(("ptbal_rho_g_"+label).c_str(), "GEN p_{T}(#rho)/p_{T}(#gamma);ratio;events", 120, 0., 3.0);
      h_hcand_m  = dir.make<TH1F>(("hcand_m_"+label).c_str(),  "GEN m(#pi#pi#gamma);m [GeV];events", 240, 0., 240.);
      h_hcand_pt = dir.make<TH1F>(("hcand_pt_"+label).c_str(), "GEN p_{T}(#pi#pi#gamma);p_{T} [GeV];events", 200, 0., 400.);
      h_rho_m_vs_pt   = dir.make<TH2F>(("rho_m_vs_pt_"+label).c_str(),   "GEN m(#pi#pi) vs p_{T}(#rho);p_{T} [GeV];m [GeV]", 120, 0., 240., 120, 0., 2.0);
      h_hcand_m_vs_pt = dir.make<TH2F>(("hcand_m_vs_pt_"+label).c_str(), "GEN m(Hcand) vs p_{T}(Hcand);p_{T} [GeV];m [GeV]", 120, 0., 360., 120, 0., 240.);
    }

    void fillH(const reco::GenParticle& H) { if (h_H_pt) h_H_pt->Fill(toF(H.pt())); if (h_H_eta) h_H_eta->Fill(toF(H.eta())); }
    void fillGamma(const SimpleCand& g) { if (h_g_pt) h_g_pt->Fill(g.pt); if (h_g_eta) h_g_eta->Fill(g.eta); }
    void fillPions(const std::vector<SimpleCand>& pions) {
      if (h_n_pi) h_n_pi->Fill(toF((int)pions.size()));
      for (const auto& pi : pions) { if (h_pi_pt) h_pi_pt->Fill(pi.pt); if (h_pi_eta) h_pi_eta->Fill(pi.eta); }
    }
    void fillRho(const RhoCand& rho) {
      if (h_rho_m) h_rho_m->Fill(rho.mass);
      if (h_rho_pt) h_rho_pt->Fill(toF(rho.p4.Pt()));
      if (h_rho_m_vs_pt) h_rho_m_vs_pt->Fill(toF(rho.p4.Pt()), rho.mass);
      const float dr = toF(reco::deltaR(rho.piPlus.eta, rho.piPlus.phi, rho.piMinus.eta, rho.piMinus.phi));
      if (h_dr_pi_pi) h_dr_pi_pi->Fill(dr);
    }
    void fillHcand(const HCand& hc) {
      if (h_hcand_m) h_hcand_m->Fill(hc.mass);
      if (h_hcand_pt) h_hcand_pt->Fill(toF(hc.p4.Pt()));
      if (h_hcand_m_vs_pt) h_hcand_m_vs_pt->Fill(toF(hc.p4.Pt()), hc.mass);
      const float dr = toF(reco::deltaR(hc.gamma.eta, hc.gamma.phi, hc.rho.eta(), hc.rho.phi()));
      if (h_dr_g_rho) h_dr_g_rho->Fill(dr);
      if (hc.gamma.pt > 0.f) { const float r = hc.rho.pt() / hc.gamma.pt; if (h_ptbal_rho_g) h_ptbal_rho_g->Fill(r); }
    }
  };

  struct ScoutHistPack {
    TH1F* h_g_pt{nullptr}; TH1F* h_g_eta{nullptr};
    TH1F* h_tk_pt{nullptr}; TH1F* h_tk_eta{nullptr}; TH1F* h_tk_dxy{nullptr}; TH1F* h_tk_dz{nullptr}; TH1F* h_tk_layers{nullptr};
    TH1F* h_rho_m{nullptr}; TH1F* h_rho_pt{nullptr};
    TH1F* h_hcand_m{nullptr}; TH1F* h_hcand_pt{nullptr};
    TH1F* h_dr_g_rho{nullptr};

    void book(TFileDirectory& dir, const std::string& label) {
      h_g_pt  = dir.make<TH1F>(("g_pt_"+label).c_str(),  "SCOUT #gamma p_{T};p_{T} [GeV];events", 200, 0., 400.);
      h_g_eta = dir.make<TH1F>(("g_eta_"+label).c_str(), "SCOUT #gamma #eta;#eta;events",         120, -6., 6.);
      h_tk_pt     = dir.make<TH1F>(("tk_pt_"+label).c_str(),     "SCOUT track p_{T};p_{T} [GeV];tracks", 200, 0., 50.);
      h_tk_eta    = dir.make<TH1F>(("tk_eta_"+label).c_str(),    "SCOUT track #eta;#eta;tracks",         120, -3., 3.);
      h_tk_dxy    = dir.make<TH1F>(("tk_dxy_"+label).c_str(),    "SCOUT track dxy;dxy [cm];tracks",      200, -0.5, 0.5);
      h_tk_dz     = dir.make<TH1F>(("tk_dz_"+label).c_str(),     "SCOUT track dz;dz [cm];tracks",        200, -1.0, 1.0);
      h_tk_layers = dir.make<TH1F>(("tk_layers_"+label).c_str(), "SCOUT nLayers;nLayers;tracks",          40, -0.5, 39.5);
      h_rho_m  = dir.make<TH1F>(("rho_m_"+label).c_str(),   "SCOUT m(#pi#pi);m [GeV];events", 200, 0., 2.0);
      h_rho_pt = dir.make<TH1F>(("rho_pt_"+label).c_str(),  "SCOUT #rho p_{T};p_{T} [GeV];events", 200, 0., 250.);
      h_hcand_m  = dir.make<TH1F>(("hcand_m_"+label).c_str(),  "SCOUT m(#pi#pi#gamma);m [GeV];events", 240, 0., 240.);
      h_hcand_pt = dir.make<TH1F>(("hcand_pt_"+label).c_str(), "SCOUT p_{T}(#pi#pi#gamma);p_{T} [GeV];events", 200, 0., 400.);
      h_dr_g_rho = dir.make<TH1F>(("dr_g_rho_"+label).c_str(), "SCOUT #DeltaR(#gamma,#rho);#DeltaR;events", 120, 0., 6.0);
    }

    void fillPhoton(const SimpleCand& g) { if (h_g_pt) h_g_pt->Fill(g.pt); if (h_g_eta) h_g_eta->Fill(g.eta); }
    void fillTrackInclusive(const Run3ScoutingTrack& t) {
      if (h_tk_pt) h_tk_pt->Fill(toF(t.tk_pt()));
      if (h_tk_eta) h_tk_eta->Fill(toF(t.tk_eta()));
      if (h_tk_layers) h_tk_layers->Fill(toF(t.tk_nTrackerLayersWithMeasurement()));
      if (h_tk_dxy) h_tk_dxy->Fill(toF(t.tk_dxy()));
      if (h_tk_dz) h_tk_dz->Fill(toF(t.tk_dz()));
    }
    void fillRho(const RhoCand& rho) { if (h_rho_m) h_rho_m->Fill(rho.mass); if (h_rho_pt) h_rho_pt->Fill(toF(rho.p4.Pt())); }
    void fillHcand(const HCand& hc) {
      if (h_hcand_m) h_hcand_m->Fill(hc.mass);
      if (h_hcand_pt) h_hcand_pt->Fill(toF(hc.p4.Pt()));
      if (h_dr_g_rho) h_dr_g_rho->Fill(toF(reco::deltaR(hc.gamma.eta, hc.gamma.phi, hc.rho.eta(), hc.rho.phi())));
    }
    void fillParticleInclusive(const Run3ScoutingParticle& p, bool useTrkVars=false) {
      const float pt  = useTrkVars ? toF(p.trk_pt())  : toF(p.pt());
      const float eta = useTrkVars ? toF(p.trk_eta()) : toF(p.eta());
      if (h_tk_pt)  h_tk_pt->Fill(pt);
      if (h_tk_eta) h_tk_eta->Fill(eta);
      if (h_tk_dxy) h_tk_dxy->Fill(toF(p.dxy()));
      if (h_tk_dz)  h_tk_dz->Fill(toF(p.dz()));
    }
  };

