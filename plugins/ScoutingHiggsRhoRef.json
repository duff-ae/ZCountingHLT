      h_piM_phi = dir.make<TH1F>(("piM_phi_"+label).c_str(), "#pi^{-} #phi;#phi;pairs",         128, -3.2, 3.2);
      h_piM_dxy = dir.make<TH1F>(("piM_dxy_"+label).c_str(), "#pi^{-} dxy;dxy [cm];pairs",      200, -0.5, 0.5);
      h_piM_dz  = dir.make<TH1F>(("piM_dz_"+label).c_str(),  "#pi^{-} dz;dz [cm];pairs",        240, -1.2, 1.2);
      h_piM_normchi2 = dir.make<TH1F>(("piM_normchi2_"+label).c_str(), "#pi^{-} norm#chi^{2};#chi^{2}/ndof;pairs", 200, 0., 20.);
      h_piM_dxysig   = dir.make<TH1F>(("piM_dxysig_"+label).c_str(),   "#pi^{-} dxy/#sigma;dxy/#sigma;pairs",       240, -12., 12.);
      h_piM_dzsig    = dir.make<TH1F>(("piM_dzsig_"+label).c_str(),    "#pi^{-} dz/#sigma;dz/#sigma;pairs",         240, -12., 12.);
      h_piM_lostInnerHits = dir.make<TH1F>(("piM_lostInnerHits_"+label).c_str(), "#pi^{-} lostInnerHits;lostInnerHits;pairs", 31, -0.5, 30.5);
      h_piM_quality  = dir.make<TH1F>(("piM_quality_"+label).c_str(),  "#pi^{-} quality;quality;pairs", 256, -0.5, 255.5);

