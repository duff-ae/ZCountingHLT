    void fill(const Run3ScoutingParticle& piP, const Run3ScoutingParticle& piM, bool useTrkVars) {
      const float ptP  = pf_pt(piP, useTrkVars),  etaP = pf_eta(piP, useTrkVars),  phiP = pf_phi(piP, useTrkVars);
      const float ptM  = pf_pt(piM, useTrkVars),  etaM = pf_eta(piM, useTrkVars),  phiM = pf_phi(piM, useTrkVars);

      if (h_piP_pt)  h_piP_pt->Fill(ptP);
      if (h_piP_eta) h_piP_eta->Fill(etaP);
      if (h_piP_phi) h_piP_phi->Fill(phiP);

      if (h_piP_dxy) h_piP_dxy->Fill(toF(piP.dxy()));
      if (h_piP_dz)  h_piP_dz->Fill(toF(piP.dz()));

      if (h_piM_pt)  h_piM_pt->Fill(ptM);
      if (h_piM_eta) h_piM_eta->Fill(etaM);
      if (h_piM_phi) h_piM_phi->Fill(phiM);

      if (h_piM_dxy) h_piM_dxy->Fill(toF(piM.dxy()));
      if (h_piM_dz)  h_piM_dz->Fill(toF(piM.dz()));
      if (h_piM_normchi2) h_piM_normchi2->Fill(toF(piM.normchi2()));
      if (h_piM_dxysig) h_piM_dxysig->Fill(toF(piM.dxysig()));
      if (h_piM_dzsig) h_piM_dzsig->Fill(toF(piM.dzsig()));
      if (h_piM_lostInnerHits) h_piM_lostInnerHits->Fill(toF(piM.lostInnerHits()));
      if (h_piM_quality) h_piM_quality->Fill(toF(piM.quality()));

      TLorentzVector vP, vM; setP4_pion(vP, ptP, etaP, phiP); setP4_pion(vM, ptM, etaM, phiM);
      TLorentzVector v = vP + vM;

      if (h_pair_m) h_pair_m->Fill(toF(v.M()));
      if (h_pair_pt) h_pair_pt->Fill(toF(v.Pt()));
      if (h_pair_eta) h_pair_eta->Fill(toF(v.Eta()));
      if (h_pair_phi) h_pair_phi->Fill(toF(v.Phi()));
      if (h_pair_dr2) h_pair_dr2->Fill(deltaR2(etaP, phiP, etaM, phiM));

      const float denom = (ptP + ptM);
      if (denom > 0.f && h_pair_asym) h_pair_asym->Fill((ptP - ptM) / denom);

      const bool sameV = (piP.vertex() == piM.vertex());
      if (h_pair_sameVtx) h_pair_sameVtx->Fill(sameV ? 1.0 : 0.0);
      if (h_pair_dz_diff)  h_pair_dz_diff->Fill(std::abs(toF(piP.dz())  - toF(piM.dz())));
      if (h_pair_dxy_diff) h_pair_dxy_diff->Fill(std::abs(toF(piP.dxy()) - toF(piM.dxy())));

      if (h_pi_pt_corr)  h_pi_pt_corr->Fill(ptP, ptM);
      if (h_pi_eta_corr) h_pi_eta_corr->Fill(etaP, etaM);
      if (h_pi_dxy_corr) h_pi_dxy_corr->Fill(toF(piP.dxy()), toF(piM.dxy()));
      if (h_pi_dz_corr)  h_pi_dz_corr->Fill(toF(piP.dz()),  toF(piM.dz()));
    }
  };

