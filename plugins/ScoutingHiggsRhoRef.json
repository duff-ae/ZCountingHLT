      h_phMult    = dir.make<TH1F>(("jet_phMult_"+label).c_str(),    "photon multiplicity;N;jets",         100, -0.5, 99.5);
      h_elMult    = dir.make<TH1F>(("jet_elMult_"+label).c_str(),    "electron multiplicity;N;jets",       100, -0.5, 99.5);
      h_muMult    = dir.make<TH1F>(("jet_muMult_"+label).c_str(),    "muon multiplicity;N;jets",           100, -0.5, 99.5);
      h_hfHadMult = dir.make<TH1F>(("jet_hfHadMult_"+label).c_str(), "HF hadron multiplicity;N;jets",      100, -0.5, 99.5);
      h_hfEMMult  = dir.make<TH1F>(("jet_hfEMMult_"+label).c_str(),  "HF EM multiplicity;N;jets",          100, -0.5, 99.5);
    }

    void fill(const Run3ScoutingPFJet& j) {
      if (h_chf) h_chf->Fill(jetCHF(j));
      if (h_nhf) h_nhf->Fill(jetNHF(j));
      if (h_phf) h_phf->Fill(jetPHF(j));
      if (h_elf) h_elf->Fill(jetELF(j));
      if (h_muf) h_muf->Fill(jetMUF(j));
      if (h_hff) h_hff->Fill(jetHFF(j));
      if (h_hof) h_hof->Fill(jetHOF(j));

      if (h_chMult)    h_chMult->Fill(toF(j.chargedHadronMultiplicity()));
      if (h_nhMult)    h_nhMult->Fill(toF(j.neutralHadronMultiplicity()));
      if (h_phMult)    h_phMult->Fill(toF(j.photonMultiplicity()));
      if (h_elMult)    h_elMult->Fill(toF(j.electronMultiplicity()));
      if (h_muMult)    h_muMult->Fill(toF(j.muonMultiplicity()));
      if (h_hfHadMult) h_hfHadMult->Fill(toF(j.HFHadronMultiplicity()));
      if (h_hfEMMult)  h_hfEMMult->Fill(toF(j.HFEMMultiplicity()));
    }
  };

