  struct ScoutJetCompPack {
    TH1F* h_chf{nullptr}; TH1F* h_nhf{nullptr}; TH1F* h_phf{nullptr};
    TH1F* h_elf{nullptr}; TH1F* h_muf{nullptr}; TH1F* h_hff{nullptr}; TH1F* h_hof{nullptr};
    TH1F* h_chMult{nullptr}; TH1F* h_nhMult{nullptr}; TH1F* h_phMult{nullptr};
    TH1F* h_elMult{nullptr}; TH1F* h_muMult{nullptr}; TH1F* h_hfHadMult{nullptr}; TH1F* h_hfEMMult{nullptr};

    void book(TFileDirectory& dir, const std::string& label) {
      h_chf = dir.make<TH1F>(("jet_chf_"+label).c_str(), "jet charged hadron frac;frac;jets", 120, 0., 1.2);
      h_nhf = dir.make<TH1F>(("jet_nhf_"+label).c_str(), "jet neutral hadron frac;frac;jets", 120, 0., 1.2);
      h_phf = dir.make<TH1F>(("jet_phf_"+label).c_str(), "jet photon frac;frac;jets",         120, 0., 1.2);
      h_elf = dir.make<TH1F>(("jet_elf_"+label).c_str(), "jet electron frac;frac;jets",       120, 0., 1.2);
      h_muf = dir.make<TH1F>(("jet_muf_"+label).c_str(), "jet muon frac;frac;jets",           120, 0., 1.2);
      h_hff = dir.make<TH1F>(("jet_hff_"+label).c_str(), "jet HF frac;frac;jets",             120, 0., 1.2);
      h_hof = dir.make<TH1F>(("jet_hof_"+label).c_str(), "jet HO frac;frac;jets",             120, 0., 1.2);

