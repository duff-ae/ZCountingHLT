  // ----------------------------
  // Jet helpers + packs
  // ----------------------------
  inline float jetEsum(const Run3ScoutingPFJet& j) {
    return toF(j.chargedHadronEnergy()) + toF(j.neutralHadronEnergy()) +
           toF(j.photonEnergy()) + toF(j.electronEnergy()) + toF(j.muonEnergy()) +
           toF(j.HFHadronEnergy()) + toF(j.HFEMEnergy()) + toF(j.HOEnergy());
  }
  inline float jetFrac(const float e, const float esum) { return (esum > 0.f) ? (e / esum) : 0.f; }
  inline float jetCHF(const Run3ScoutingPFJet& j) { const float s=jetEsum(j); return jetFrac(toF(j.chargedHadronEnergy()), s); }
  inline float jetNHF(const Run3ScoutingPFJet& j) { const float s=jetEsum(j); return jetFrac(toF(j.neutralHadronEnergy()), s); }
  inline float jetPHF(const Run3ScoutingPFJet& j) { const float s=jetEsum(j); return jetFrac(toF(j.photonEnergy()), s); }
  inline float jetELF(const Run3ScoutingPFJet& j) { const float s=jetEsum(j); return jetFrac(toF(j.electronEnergy()), s); }
  inline float jetMUF(const Run3ScoutingPFJet& j) { const float s=jetEsum(j); return jetFrac(toF(j.muonEnergy()), s); }
  inline float jetHFF(const Run3ScoutingPFJet& j) { const float s=jetEsum(j); return jetFrac(toF(j.HFHadronEnergy()) + toF(j.HFEMEnergy()), s); }
  inline float jetHOF(const Run3ScoutingPFJet& j) { const float s=jetEsum(j); return jetFrac(toF(j.HOEnergy()), s); }

