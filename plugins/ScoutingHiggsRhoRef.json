  // PF matched pion-pair correlations (only for "pfc_match" pair)
  struct PFMatchedPairPack {
    TH1F* h_piP_pt{nullptr}; TH1F* h_piP_eta{nullptr}; TH1F* h_piP_phi{nullptr}; TH1F* h_piP_dxy{nullptr}; TH1F* h_piP_dz{nullptr};
    TH1F* h_piP_normchi2{nullptr}; TH1F* h_piP_dxysig{nullptr}; TH1F* h_piP_dzsig{nullptr}; TH1F* h_piP_lostInnerHits{nullptr}; TH1F* h_piP_quality{nullptr};
    TH1F* h_piM_pt{nullptr}; TH1F* h_piM_eta{nullptr}; TH1F* h_piM_phi{nullptr}; TH1F* h_piM_dxy{nullptr}; TH1F* h_piM_dz{nullptr};
    TH1F* h_piM_normchi2{nullptr}; TH1F* h_piM_dxysig{nullptr}; TH1F* h_piM_dzsig{nullptr}; TH1F* h_piM_lostInnerHits{nullptr}; TH1F* h_piM_quality{nullptr};

    TH1F* h_pair_m{nullptr}; TH1F* h_pair_pt{nullptr}; TH1F* h_pair_eta{nullptr}; TH1F* h_pair_phi{nullptr}; TH1F* h_pair_dr2{nullptr};
    TH1F* h_pair_asym{nullptr}; TH1F* h_pair_sameVtx{nullptr}; TH1F* h_pair_dz_diff{nullptr}; TH1F* h_pair_dxy_diff{nullptr};
    TH2F* h_pi_pt_corr{nullptr}; TH2F* h_pi_eta_corr{nullptr}; TH2F* h_pi_dxy_corr{nullptr}; TH2F* h_pi_dz_corr{nullptr};

    void book(TFileDirectory& dir, const std::string& label) {
      h_piP_pt  = dir.make<TH1F>(("piP_pt_"+label).c_str(),  "#pi^{+} p_{T};p_{T} [GeV];pairs", 240, 0., 120.);
      h_piP_eta = dir.make<TH1F>(("piP_eta_"+label).c_str(), "#pi^{+} #eta;#eta;pairs",         160, -4., 4.);
      h_piP_phi = dir.make<TH1F>(("piP_phi_"+label).c_str(), "#pi^{+} #phi;#phi;pairs",         128, -3.2, 3.2);
      h_piP_dxy = dir.make<TH1F>(("piP_dxy_"+label).c_str(), "#pi^{+} dxy;dxy [cm];pairs",      200, -0.5, 0.5);
      h_piP_dz  = dir.make<TH1F>(("piP_dz_"+label).c_str(),  "#pi^{+} dz;dz [cm];pairs",        240, -1.2, 1.2);
      h_piP_normchi2 = dir.make<TH1F>(("piP_normchi2_"+label).c_str(), "#pi^{+} norm#chi^{2};#chi^{2}/ndof;pairs", 200, 0., 20.);
      h_piP_dxysig   = dir.make<TH1F>(("piP_dxysig_"+label).c_str(),   "#pi^{+} dxy/#sigma;dxy/#sigma;pairs",       240, -12., 12.);
      h_piP_dzsig    = dir.make<TH1F>(("piP_dzsig_"+label).c_str(),    "#pi^{+} dz/#sigma;dz/#sigma;pairs",         240, -12., 12.);
      h_piP_lostInnerHits = dir.make<TH1F>(("piP_lostInnerHits_"+label).c_str(), "#pi^{+} lostInnerHits;lostInnerHits;pairs", 31, -0.5, 30.5);
