    TH2F* h_resp_pt_vs_emf{nullptr};

    void book(TFileDirectory& dir) {
      h_genjet_pt_den = dir.make<TH1F>("genjet_pt_den", "DEN: GEN jet p_{T};p_{T}^{gen} [GeV];jets", 300, 0., 600.);
      h_genjet_pt_num = dir.make<TH1F>("genjet_pt_num", "NUM: matched SCOUT jet;p_{T}^{gen} [GeV];jets", 300, 0., 600.);
      h_dr2           = dir.make<TH1F>("dr2_gen_scout", "#DeltaR^{2}(GEN jet, SCOUT jet);#DeltaR^{2};jets", 200, 0., 1.0);
      h_resp_pt       = dir.make<TH1F>("resp_pt", "p_{T} response; p_{T}^{scout}/p_{T}^{gen};jets", 160, 0., 3.2);
      h_resp_pt_vs_eta= dir.make<TH2F>("resp_pt_vs_eta", "p_{T} response vs #eta;#eta;p_{T}^{scout}/p_{T}^{gen}", 120, -5., 5., 120, 0., 3.0);
      h_emf = dir.make<TH1F>("emf", "EM frac (e+#gamma)/sumE;EMF;jets", 120, 0., 1.2);
      h_resp_pt_vs_emf= dir.make<TH2F>("resp_pt_vs_emf", "p_{T} response vs EMF;EMF;p_{T}^{scout}/p_{T}^{gen}", 120, 0., 1.2, 120, 0., 3.0);
    }
  };

