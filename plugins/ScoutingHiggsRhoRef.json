// ScoutingHiggsRho.cc  (BLOCK 2/3)
// ===========================

bool ScoutingHiggsRho::buildGenCandidates_(const edm::Event& ev, bool fidOnly,
                                           bool& hasH, bool& hasG, bool& hasPiPi, bool& hasHcand,
                                           const reco::GenParticle*& higgsOut,
                                           SimpleCand& gammaOut, RhoCand& rhoOut, HCand& hcOut) const {
  hasH = hasG = hasPiPi = hasHcand = false;
  higgsOut = nullptr;
  gammaOut = SimpleCand{};
  rhoOut = RhoCand{};
  hcOut = HCand{};
  hcOut.p4.SetPxPyPzE(0,0,0,0);

  edm::Handle<std::vector<reco::GenParticle>> hPruned;
  ev.getByToken(prunedGenTok_, hPruned);
  if (!hPruned.isValid()) return false;

  const reco::GenParticle* higgs = findLeadingHiggs_(*hPruned);
  if (!higgs) return true;
  hasH = true;
  higgsOut = higgs;

  const reco::GenParticle* gamPruned = findGammaFromPrunedDesc_(higgs);

  edm::Handle<std::vector<pat::PackedGenParticle>> hPacked;
  ev.getByToken(packedGenTok_, hPacked);

  std::vector<SimpleCand> pionsPacked;
  const pat::PackedGenParticle* gamPacked = nullptr;
  if (hPacked.isValid()) collectPackedFromHiggs_(*hPacked, pionsPacked, gamPacked);

  auto acceptGammaFid = [&](float eta) { return passAbsEta(eta, fidPhoMaxAbsEta_); };
  auto acceptPionFid  = [&](float eta) { return passAbsEta(eta, fidPiMaxAbsEta_); };

  if (gamPruned) {
    const float pt  = toF(gamPruned->pt());
    const float eta = toF(gamPruned->eta());
    const float phi = toF(gamPruned->phi());
    if (pt >= genPhoMinPt_ && (!fidOnly || acceptGammaFid(eta))) {
      hasG = true;
      gammaOut.pt = pt; gammaOut.eta = eta; gammaOut.phi = phi; gammaOut.mass = 0.f; gammaOut.charge = 0;
    }
  }
  if (!hasG && gamPacked) {
    const float pt  = toF(gamPacked->pt());
    const float eta = toF(gamPacked->eta());
    const float phi = toF(gamPacked->phi());
    if (pt >= genPhoMinPt_ && (!fidOnly || acceptGammaFid(eta))) {
      hasG = true;
      gammaOut.pt = pt; gammaOut.eta = eta; gammaOut.phi = phi; gammaOut.mass = 0.f; gammaOut.charge = 0;
    }
  }

  std::vector<SimpleCand> pionCands;
  pionCands.reserve(pionsPacked.size());
  for (const auto& pi : pionsPacked) {
    if (pi.pt < genPiMinPt_) continue;
    if (fidOnly && !acceptPionFid(pi.eta)) continue;
    pionCands.push_back(pi);
  }

  if (pionCands.empty()) {
    for (const auto& gp : *hPruned) {
      if (std::abs(gp.pdgId()) != 211) continue;
      if (!hasAncestorPdgIdAbs(&gp, 25)) continue;
      const float pt  = toF(gp.pt());
      const float eta = toF(gp.eta());
      const float phi = toF(gp.phi());
      if (pt < genPiMinPt_) continue;
      if (fidOnly && !acceptPionFid(eta)) continue;
      SimpleCand c; c.pt=pt; c.eta=eta; c.phi=phi; c.mass=M_PI_CH; c.charge=(gp.pdgId()==211?+1:-1);
      pionCands.push_back(c);
    }
  }

  SimpleCand piP, piM;
  RhoCand rho;
  if (!pionCands.empty() && bestPionPairToRho(pionCands, piP, piM, rho)) { hasPiPi = true; rhoOut = rho; }

  if (hasG && hasPiPi) {
    TLorentzVector vg, vh;
    setP4_massless(vg, gammaOut.pt, gammaOut.eta, gammaOut.phi);
    vh = vg + rhoOut.p4;
    hasHcand = true;
    hcOut.gamma = gammaOut;
    hcOut.rho = rhoOut;
    hcOut.p4 = vh;
    hcOut.mass = toF(vh.M());
  }
  return true;
}

bool ScoutingHiggsRho::selectBestScoutPhoton_(const std::vector<Run3ScoutingPhoton>& phos, SimpleCand& out) const {
  int best = -1; float bestPt = -1.f;
  for (size_t i = 0; i < phos.size(); ++i) {
    const auto& p = phos[i];
    const float pt = toF(p.pt());
    const float eta = toF(p.eta());
    if (pt < toF(phoMinPt_)) continue;
    if (phoMaxAbsEta_ > 0.0 && std::abs(eta) > toF(phoMaxAbsEta_)) continue;
    if (pt > bestPt) { bestPt = pt; best = int(i); }
  }
  if (best < 0) return false;
  const auto& p = phos[best];
  out.pt = toF(p.pt()); out.eta = toF(p.eta()); out.phi = toF(p.phi()); out.mass = 0.f; out.charge = 0;
  return true;
}

bool ScoutingHiggsRho::selectBestScoutPhotonGivenRho_(const std::vector<Run3ScoutingPhoton>& phos, const TLorentzVector& rhoP4,
                                                      SimpleCand& out, float& outBestScore) const {
  int best = -1; float bestScore = 1e9f;
  for (size_t i = 0; i < phos.size(); ++i) {
    const auto& p = phos[i];
    const float pt  = toF(p.pt());
    const float eta = toF(p.eta());
    const float phi = toF(p.phi());
    if (pt < toF(phoMinPt_)) continue;
    if (phoMaxAbsEta_ > 0.0 && std::abs(eta) > toF(phoMaxAbsEta_)) continue;

    TLorentzVector gP4; setP4_massless(gP4, pt, eta, phi);
    const TLorentzVector hP4 = rhoP4 + gP4;
    const float mHcand = toF(hP4.M());

    const float dphi = absDeltaPhi(phi, toF(rhoP4.Phi()));
    const float dEta = eta - toF(rhoP4.Eta());
    const float dR2  = dEta*dEta + dphi*dphi;

    const float pull_m   = (mHcand - M_H) / 8.0f;
    const float pull_pt  = (pt - 60.0f) / 25.0f;
    const float pull_top = (dphi - float(M_PI)) / 0.6f;

    const float score = pull_m*pull_m + 0.35f*pull_pt*pull_pt + 0.25f*pull_top*pull_top + 0.05f*(dR2/1.0f);
    if (score < bestScore) { bestScore = score; best = int(i); }
  }
  outBestScore = bestScore;
  if (best < 0) return false;
  const auto& p = phos[best];
  out.pt = toF(p.pt()); out.eta = toF(p.eta()); out.phi = toF(p.phi()); out.mass = 0.f; out.charge = 0;
  return true;
}

bool ScoutingHiggsRho::bestScoutTrackPairToRho_(const std::vector<Run3ScoutingTrack>& tks, RhoCand& rhoOut) const {
  float bestDiff = std::numeric_limits<float>::infinity();
  bool found = false;
  TLorentzVector best; float bestMass = -1.f;
  SimpleCand bestP{}, bestM{};

  auto passTk = [&](const Run3ScoutingTrack& t) { return passScoutTkQuality_(t); };

  for (size_t i = 0; i < tks.size(); ++i) {
    const auto& a = tks[i];
    if (!passTk(a)) continue;
    for (size_t j = i + 1; j < tks.size(); ++j) {
      const auto& b = tks[j];
      if (!passTk(b)) continue;
      const int qa = a.tk_charge();
      const int qb = b.tk_charge();
      if (qa * qb >= 0) continue;

      TLorentzVector va, vb;
      setP4_pion(va, toF(a.tk_pt()), toF(a.tk_eta()), toF(a.tk_phi()));
      setP4_pion(vb, toF(b.tk_pt()), toF(b.tk_eta()), toF(b.tk_phi()));
      TLorentzVector v = va + vb;
      const float m = toF(v.M());
      const float diff = std::abs(m - M_RHO);
      if (diff < bestDiff) {
        bestDiff = diff; best = v; bestMass = m; found = true;
        SimpleCand ca, cb;
        ca.pt=toF(a.tk_pt()); ca.eta=toF(a.tk_eta()); ca.phi=toF(a.tk_phi()); ca.mass=M_PI_CH; ca.charge=qa;
        cb.pt=toF(b.tk_pt()); cb.eta=toF(b.tk_eta()); cb.phi=toF(b.tk_phi()); cb.mass=M_PI_CH; cb.charge=qb;
        if (qa > 0) { bestP = ca; bestM = cb; } else { bestP = cb; bestM = ca; }
      }
    }
  }
  if (!found) return false;
  rhoOut.piPlus = bestP; rhoOut.piMinus = bestM; rhoOut.p4 = best; rhoOut.mass = bestMass;
  return true;
}

ScoutingHiggsRho::ScoutingHiggsRho(const edm::ParameterSet& cfg) {
  usesResource("TFileService");

  storeGEN_        = cfg.getUntrackedParameter<bool>("storeGEN", true);
  storeHistograms_ = cfg.getUntrackedParameter<bool>("storeHistograms", true);

  genEvtTag_    = cfg.getUntrackedParameter<edm::InputTag>("genEventInfo",       edm::InputTag("generator"));
  puTag_        = cfg.getUntrackedParameter<edm::InputTag>("pileupSummary",      edm::InputTag("slimmedAddPileupInfo"));
  prunedGenTag_ = cfg.getUntrackedParameter<edm::InputTag>("prunedGenParticles", edm::InputTag("prunedGenParticles"));
  packedGenTag_ = cfg.getUntrackedParameter<edm::InputTag>("packedGenParticles", edm::InputTag("packedGenParticles"));

  fidPhoMaxAbsEta_ = toF(cfg.getUntrackedParameter<double>("fidPhoMaxAbsEta", 2.5));
  fidPiMaxAbsEta_  = toF(cfg.getUntrackedParameter<double>("fidPiMaxAbsEta",  2.5));
  genPhoMinPt_ = toF(cfg.getUntrackedParameter<double>("genPhoMinPt", 0.0));
  genPiMinPt_  = toF(cfg.getUntrackedParameter<double>("genPiMinPt",  0.0));

  matchPhoDR2_     = toF(cfg.getUntrackedParameter<double>("matchPhoDR2", 0.01));
  matchTkDR2_      = toF(cfg.getUntrackedParameter<double>("matchTkDR2",  0.01));
  doTruthMatching_ = cfg.getUntrackedParameter<bool>("doTruthMatching", true);

  doJetMatching_ = cfg.getUntrackedParameter<bool>("doJetMatching", true);
  matchJetDR2_   = toF(cfg.getUntrackedParameter<double>("matchJetDR2", 0.04)); // (0.2)^2 default

  phoTag_ = cfg.getParameter<edm::InputTag>("photonCollection");
  tkTag_  = cfg.getParameter<edm::InputTag>("trackCollection");
  pfcTag_ = cfg.getParameter<edm::InputTag>("pfCandCollection");
  jetTag_ = cfg.getParameter<edm::InputTag>("pfJetCollection");

  phoMinPt_     = toF(cfg.getUntrackedParameter<double>("phoMinPt", 0.0));
  phoMaxAbsEta_ = toF(cfg.getUntrackedParameter<double>("phoMaxAbsEta", 0.0));

  tkMinPt_      = toF(cfg.getUntrackedParameter<double>("tkMinPt", 1.0));
  tkMaxAbsEta_  = toF(cfg.getUntrackedParameter<double>("tkMaxAbsEta", 2.4));
  tkMinLayers_  = cfg.getUntrackedParameter<int>("tkMinLayers", 4);
  tkMaxAbsDz_   = toF(cfg.getUntrackedParameter<double>("tkMaxAbsDz", 0.2));
  tkMaxAbsDxy_  = toF(cfg.getUntrackedParameter<double>("tkMaxAbsDxy", 0.1));

  pfcMinPt_     = toF(cfg.getUntrackedParameter<double>("pfcMinPt", 1.0));
  pfcMaxAbsEta_ = toF(cfg.getUntrackedParameter<double>("pfcMaxAbsEta", 2.4));
  pfcMaxAbsDz_  = toF(cfg.getUntrackedParameter<double>("pfcMaxAbsDz", 0.2));
  pfcMaxAbsDxy_ = toF(cfg.getUntrackedParameter<double>("pfcMaxAbsDxy", 0.1));

  pfPionOnly_   = cfg.getUntrackedParameter<bool>("pfPionOnly", true);
  pfUseTrkVars_ = cfg.getUntrackedParameter<bool>("pfUseTrkVars", false);

  pfRequireSameVtx_ = cfg.getUntrackedParameter<bool>("pfRequireSameVtx", true);
  pfMaxAbsDzDiff_   = toF(cfg.getUntrackedParameter<double>("pfMaxAbsDzDiff",  0.05));
  pfMaxAbsDxyDiff_  = toF(cfg.getUntrackedParameter<double>("pfMaxAbsDxyDiff", 0.05));

  pfRhoMinPt_       = toF(cfg.getUntrackedParameter<double>("pfRhoMinPt", 15.0));
  pfMinAbsDPhiGRho_ = toF(cfg.getUntrackedParameter<double>("pfMinAbsDPhiGRho", 2.7));
  pfMinPtBal_       = toF(cfg.getUntrackedParameter<double>("pfMinPtBal", 0.5));
  pfMaxPtBal_       = toF(cfg.getUntrackedParameter<double>("pfMaxPtBal", 2.0));

  pfRhoMassMin_     = toF(cfg.getUntrackedParameter<double>("pfRhoMassMin", 0.0));
  pfRhoMassMax_     = toF(cfg.getUntrackedParameter<double>("pfRhoMassMax", 0.0));

  jetMinPt_     = toF(cfg.getUntrackedParameter<double>("jetMinPt", 30.0));
  htJetMinPt_   = toF(cfg.getUntrackedParameter<double>("htJetMinPt", 30.0));
  jetMaxAbsEta_ = toF(cfg.getUntrackedParameter<double>("jetMaxAbsEta", 4.7));

  genJetTag_ = cfg.getUntrackedParameter<edm::InputTag>("genJetCollection", edm::InputTag("slimmedGenJets"));
  genJetMinPt30_   = toF(cfg.getUntrackedParameter<double>("genJetMinPt30", 30.0));
  genJetMinPt15_   = toF(cfg.getUntrackedParameter<double>("genJetMinPt15", 15.0));
  genJetMaxAbsEta_ = toF(cfg.getUntrackedParameter<double>("genJetMaxAbsEta", 4.7));
  genJetSignalDR_  = toF(cfg.getUntrackedParameter<double>("genJetSignalDR", 0.4));

  genEvtTok_    = consumes<GenEventInfoProduct>(genEvtTag_);
  puTok_        = consumes<std::vector<PileupSummaryInfo>>(puTag_);
  prunedGenTok_ = consumes<std::vector<reco::GenParticle>>(prunedGenTag_);
  packedGenTok_ = consumes<std::vector<pat::PackedGenParticle>>(packedGenTag_);
  scoutPhoTok_  = consumes<std::vector<Run3ScoutingPhoton>>(phoTag_);
  scoutTkTok_   = consumes<std::vector<Run3ScoutingTrack>>(tkTag_);
  scoutPFCTok_  = consumes<std::vector<Run3ScoutingParticle>>(pfcTag_);
  scoutJetTok_  = consumes<std::vector<Run3ScoutingPFJet>>(jetTag_);
  genJetToken_  = consumes<reco::GenJetCollection>(genJetTag_);
}

void ScoutingHiggsRho::beginJob() {
  if (!storeHistograms_) return;

  TFileDirectory dEvt = fs_->mkdir("evt");
  h_evt_weight_   = dEvt.make<TH1F>("evt_weight",   "event weight;w;events", 200, -2., 2.);
  h_evt_nTrueInt_ = dEvt.make<TH1F>("evt_nTrueInt", "nTrueInt;nTrueInt;events", 120, 0., 120.);

  TFileDirectory dFlags = fs_->mkdir("flags");
  h_gen_flags_all_ = dFlags.make<TH1F>("gen_flags_all", "GEN flags (all);bit;events", 16, -0.5, 15.5);
  h_gen_flags_fid_ = dFlags.make<TH1F>("gen_flags_fid", "GEN flags (fid);bit;events", 16, -0.5, 15.5);

  TFileDirectory dGen = fs_->mkdir("gen");
  TFileDirectory dGenAll = dGen.mkdir("all");
  TFileDirectory dGenFid = dGen.mkdir("fid");
  genAll_.book(dGenAll, "all");
  genFid_.book(dGenFid, "fid");

  TFileDirectory dScout = fs_->mkdir("scout");
  TFileDirectory dScoutIncl = dScout.mkdir("inclusive");
  TFileDirectory dScoutMatch = dScout.mkdir("truthMatched");
  scoutIncl_.book(dScoutIncl, "incl");
  scoutMatch_.book(dScoutMatch, "match");

  TFileDirectory dMatch = fs_->mkdir("matching");
  matchH_.book(dMatch);

  TFileDirectory dScoutPFMatch = dScout.mkdir("truthMatchedPFCands");
  scoutPFMatch_.book(dScoutPFMatch, "pfc_match");
  pfPairFromPFCMatch_.book(dScoutPFMatch, "pfc_matchpair");

  TFileDirectory dScoutPFAna = dScout.mkdir("analysisPFCands");
  pfAna_.book(dScoutPFAna);

  TFileDirectory dScoutJets = dScout.mkdir("jets");
  TFileDirectory dScoutJetsIncl = dScoutJets.mkdir("inclusive");
  TFileDirectory dScoutJetsComp = dScoutJets.mkdir("composition");
  TFileDirectory dScoutJetsMatch = dScoutJets.mkdir("matching");
  scoutJetIncl_.book(dScoutJetsIncl, "incl");
  scoutJetComp_.book(dScoutJetsComp, "incl");
  jetMatch_.book(dScoutJetsMatch);

  TFileDirectory dGenJets = dGen.mkdir("jets");
  h_genjet_n_pt15_ = dGenJets.make<TH1F>("genjet_n_pt15", "N gen jets (p_{T}>15, |#eta|<4.7);N;events", 15, -0.5, 14.5);
  h_genjet_n_pt30_ = dGenJets.make<TH1F>("genjet_n_pt30", "N gen jets (p_{T}>30, |#eta|<4.7);N;events", 15, -0.5, 14.5);
  h_genjet_ht30_   = dGenJets.make<TH1F>("genjet_ht30",   "GEN H_{T} (sum p_{T} jets p_{T}>30, |#eta|<4.7);H_{T} [GeV];events", 200, 0, 1000);
  h_genjet1_pt_  = dGenJets.make<TH1F>("genjet1_pt",  "Leading gen jet p_{T};p_{T} [GeV];events", 200, 0, 1000);
  h_genjet1_eta_ = dGenJets.make<TH1F>("genjet1_eta", "Leading gen jet #eta;#eta;events", 120, -6, 6);
  h_genjet_minDR_g_   = dGenJets.make<TH1F>("genjet_minDR_g",   "min #DeltaR(genJet, gen #gamma);#DeltaR;events", 80, 0, 4.0);
  h_genjet_minDR_rho_ = dGenJets.make<TH1F>("genjet_minDR_rho", "min #DeltaR(genJet, gen #rho);#DeltaR;events",   80, 0, 4.0);
  h_genjet_n_away_30_ = dGenJets.make<TH1F>("genjet_nAway_pt30", "N gen jets away from (#gamma,#rho) (p_{T}>30);N;events", 15, -0.5, 14.5);
  h_genjet_n_near_30_ = dGenJets.make<TH1F>("genjet_nNear_pt30", "N gen jets near (#gamma,#rho) (p_{T}>30);N;events", 15, -0.5, 14.5);
}

// ===========================
// ScoutingHiggsRho.cc  (BLOCK 3/3)
// ===========================

void ScoutingHiggsRho::analyze(const edm::Event& ev, const edm::EventSetup&) {
  // 0) Event-level (safe for data and MC)
  {
    edm::Handle<GenEventInfoProduct> hW;
    ev.getByToken(genEvtTok_, hW);
    if (hW.isValid() && h_evt_weight_) h_evt_weight_->Fill(toF(hW->weight()));
  }
  {
    edm::Handle<std::vector<PileupSummaryInfo>> hPU;
    ev.getByToken(puTok_, hPU);
    if (hPU.isValid() && h_evt_nTrueInt_) {
      for (const auto& pu : *hPU) {
        if (pu.getBunchCrossing() == 0) { h_evt_nTrueInt_->Fill(toF(pu.getTrueNumInteractions())); break; }
      }
    }
  }

  edm::Handle<std::vector<Run3ScoutingPFJet>> hJet;
  ev.getByToken(scoutJetTok_, hJet);

  // ----------------------------
  // 1) GEN-only block (do NOT early return)
  // ----------------------------
  bool hasH=false, hasG=false, hasPiPi=false, hasHcand=false;
  const reco::GenParticle* H=nullptr;
  SimpleCand g; RhoCand rho; HCand hc;

  bool f_hasH=false, f_hasG=false, f_hasPiPi=false, f_hasHcand=false;
  const reco::GenParticle* f_H=nullptr;
  SimpleCand f_g; RhoCand f_rho; HCand f_hc;

  edm::Handle<reco::GenJetCollection> hGenJets;
  edm::Handle<std::vector<pat::PackedGenParticle>> hPacked;

  if (storeGEN_) {
    buildGenCandidates_(ev, false, hasH, hasG, hasPiPi, hasHcand, H, g, rho, hc);
    if (hasH && H) genAll_.fillH(*H);
    if (hasG) genAll_.fillGamma(g);

    ev.getByToken(packedGenTok_, hPacked);
    if (hPacked.isValid()) {
      std::vector<SimpleCand> pions; pions.reserve(128);
      const pat::PackedGenParticle* dummyG=nullptr;
      collectPackedFromHiggs_(*hPacked, pions, dummyG);
      std::vector<SimpleCand> pionsPt; pionsPt.reserve(pions.size());
      for (const auto& pi : pions) if (pi.pt >= genPiMinPt_) pionsPt.push_back(pi);
      genAll_.fillPions(pionsPt);
    }
    if (hasPiPi) genAll_.fillRho(rho);
    if (hasHcand) genAll_.fillHcand(hc);

    if (h_gen_flags_all_) {
      int mask=0; if (hasH) mask|=(1<<0); if (hasG) mask|=(1<<1); if (hasPiPi) mask|=(1<<2); if (hasHcand) mask|=(1<<3);
      for (int b=0;b<16;++b) if (mask&(1<<b)) h_gen_flags_all_->Fill(toF(b));
    }

    buildGenCandidates_(ev, true, f_hasH, f_hasG, f_hasPiPi, f_hasHcand, f_H, f_g, f_rho, f_hc);
    if (f_hasH && f_H) genFid_.fillH(*f_H);
    if (f_hasG) genFid_.fillGamma(f_g);

    if (hPacked.isValid()) {
      std::vector<SimpleCand> pions; pions.reserve(128);
      const pat::PackedGenParticle* dummyG=nullptr;
      collectPackedFromHiggs_(*hPacked, pions, dummyG);
      std::vector<SimpleCand> pionsF; pionsF.reserve(pions.size());
      for (const auto& pi : pions) {
        if (pi.pt < genPiMinPt_) continue;
        if (!passAbsEta(pi.eta, fidPiMaxAbsEta_)) continue;
        pionsF.push_back(pi);
      }
      genFid_.fillPions(pionsF);
    }
    if (f_hasPiPi) genFid_.fillRho(f_rho);
    if (f_hasHcand) genFid_.fillHcand(f_hc);

    if (h_gen_flags_fid_) {
      int mask=0; if (f_hasH) mask|=(1<<0); if (f_hasG) mask|=(1<<1); if (f_hasPiPi) mask|=(1<<2); if (f_hasHcand) mask|=(1<<3);
      for (int b=0;b<16;++b) if (mask&(1<<b)) h_gen_flags_fid_->Fill(toF(b));
    }

    // GEN jets diagnostics
    ev.getByToken(genJetToken_, hGenJets);
    int n15=0, n30=0; double ht30=0.0;
    double leadPt=-1.0, leadEta=0.0;

    const bool haveGenPho = hasG;
    const bool haveGenRho = hasPiPi;

    TLorentzVector genPhoP4, genRhoP4;
    if (haveGenPho) setP4_massless(genPhoP4, g.pt, g.eta, g.phi);
    if (haveGenRho) genRhoP4 = rho.p4;

    int nNear30=0, nAway30=0;
    double minDRg=999., minDRrho=999.;

    if (hGenJets.isValid()) {
      for (const auto& j : *hGenJets) {
        const double pt=j.pt(), eta=j.eta();
        if (std::abs(eta) > genJetMaxAbsEta_) continue;
        if (pt > genJetMinPt15_) n15++;
        if (pt > genJetMinPt30_) { n30++; ht30 += pt; }
        if (pt > leadPt) { leadPt=pt; leadEta=eta; }

        if (pt > genJetMinPt30_ && haveGenPho && haveGenRho) {
          const double dRg   = reco::deltaR(j.eta(), j.phi(), genPhoP4.Eta(), genPhoP4.Phi());
          const double dRrho = reco::deltaR(j.eta(), j.phi(), genRhoP4.Eta(), genRhoP4.Phi());
          if (dRg < minDRg) minDRg=dRg;
          if (dRrho < minDRrho) minDRrho=dRrho;
          const double dRmin = std::min(dRg, dRrho);
          if (dRmin < genJetSignalDR_) nNear30++; else nAway30++;
        }
      }
    }

    if (h_genjet_n_pt15_) h_genjet_n_pt15_->Fill(n15);
    if (h_genjet_n_pt30_) h_genjet_n_pt30_->Fill(n30);
    if (h_genjet_ht30_)   h_genjet_ht30_->Fill(ht30);
    if (leadPt > 0) { if (h_genjet1_pt_) h_genjet1_pt_->Fill(leadPt); if (h_genjet1_eta_) h_genjet1_eta_->Fill(leadEta); }
    if (haveGenPho && haveGenRho && minDRg < 998.)   if (h_genjet_minDR_g_)   h_genjet_minDR_g_->Fill(minDRg);
    if (haveGenPho && haveGenRho && minDRrho < 998.) if (h_genjet_minDR_rho_) h_genjet_minDR_rho_->Fill(minDRrho);
    if (haveGenPho && haveGenRho) { if (h_genjet_n_near_30_) h_genjet_n_near_30_->Fill(nNear30); if (h_genjet_n_away_30_) h_genjet_n_away_30_->Fill(nAway30); }
  }

  // ----------------------------
  // 2) Scouting inclusive + PF handles
  // ----------------------------
  edm::Handle<std::vector<Run3ScoutingPhoton>>   hPho;
  edm::Handle<std::vector<Run3ScoutingTrack>>    hTk;
  edm::Handle<std::vector<Run3ScoutingParticle>> hPFC;
  ev.getByToken(scoutPhoTok_, hPho);
  ev.getByToken(scoutTkTok_,  hTk);
  ev.getByToken(scoutPFCTok_, hPFC);

  // Inclusive track histos
  if (hTk.isValid()) for (const auto& t : *hTk) scoutIncl_.fillTrackInclusive(t);

  // Build scouting rho from tracks
  RhoCand sRho; bool hasSRho=false;
  if (hTk.isValid()) {
    if (bestScoutTrackPairToRho_(*hTk, sRho)) { hasSRho=true; scoutIncl_.fillRho(sRho); }
  }

  // Photon (prefer conditioned on rho)
  bool hasSG=false; SimpleCand sG; float bestPhoScore=1e9f;
  if (hasSRho && hPho.isValid()) {
    if (selectBestScoutPhotonGivenRho_(*hPho, sRho.p4, sG, bestPhoScore)) { hasSG=true; scoutIncl_.fillPhoton(sG); }
  } else if (hPho.isValid()) {
    if (selectBestScoutPhoton_(*hPho, sG)) { hasSG=true; scoutIncl_.fillPhoton(sG); }
  }

  if (hasSG && hasSRho) {
    TLorentzVector vg; setP4_massless(vg, sG.pt, sG.eta, sG.phi);
    HCand sH; sH.gamma=sG; sH.rho=sRho; sH.p4 = vg + sRho.p4; sH.mass=toF(sH.p4.M());
    scoutIncl_.fillHcand(sH);
  }

  // ----------------------------
  // 2A) Inclusive scouting jets
  // ----------------------------
  std::vector<int> jetIdx; jetIdx.reserve(hJet.isValid() ? hJet->size() : 0);
  double ht=0.0;

  if (hJet.isValid()) {
    for (int i=0;i<(int)hJet->size();++i) {
      const auto& j = hJet->at(i);
      const float pt=toF(j.pt()), eta=toF(j.eta());
      scoutJetIncl_.fillJet(j);
      scoutJetComp_.fill(j);
      if (pt < toF(jetMinPt_)) continue;
      if (std::abs(eta) > toF(jetMaxAbsEta_)) continue;
      jetIdx.push_back(i);
      if (pt >= toF(htJetMinPt_)) ht += pt;
    }
  }
  if (hJet.isValid() && !jetIdx.empty()) {
    std::sort(jetIdx.begin(), jetIdx.end(), [&](int a, int b){ return toF(hJet->at(a).pt()) > toF(hJet->at(b).pt()); });
  }
  if (scoutJetIncl_.h_njet) scoutJetIncl_.h_njet->Fill(toF((int)jetIdx.size()));
  if (scoutJetIncl_.h_ht)   scoutJetIncl_.h_ht->Fill(toF(ht));

  if (hJet.isValid() && jetIdx.size()>=1) {
    const auto& j1=hJet->at(jetIdx[0]);
    if (scoutJetIncl_.h_j1_pt) scoutJetIncl_.h_j1_pt->Fill(toF(j1.pt()));
    if (scoutJetIncl_.h_j1_eta) scoutJetIncl_.h_j1_eta->Fill(toF(j1.eta()));
  }
  if (hJet.isValid() && jetIdx.size()>=2) {
    const auto& j1=hJet->at(jetIdx[0]);
    const auto& j2=hJet->at(jetIdx[1]);
    if (scoutJetIncl_.h_j2_pt) scoutJetIncl_.h_j2_pt->Fill(toF(j2.pt()));
    if (scoutJetIncl_.h_j2_eta) scoutJetIncl_.h_j2_eta->Fill(toF(j2.eta()));
    TLorentzVector v1, v2;
    v1.SetPtEtaPhiM(toF(j1.pt()), toF(j1.eta()), toF(j1.phi()), toF(j1.m()));
    v2.SetPtEtaPhiM(toF(j2.pt()), toF(j2.eta()), toF(j2.phi()), toF(j2.m()));
    const TLorentzVector v = v1+v2;
    if (scoutJetIncl_.h_mjj) scoutJetIncl_.h_mjj->Fill(toF(v.M()));
    const float dphi=absDeltaPhi(toF(j1.phi()), toF(j2.phi()));
    if (scoutJetIncl_.h_dphi_jj) scoutJetIncl_.h_dphi_jj->Fill(dphi);
    if (scoutJetIncl_.h_dr2_jj) scoutJetIncl_.h_dr2_jj->Fill(deltaR2(toF(j1.eta()), toF(j1.phi()), toF(j2.eta()), toF(j2.phi())));
  }

  // 2B) Jet correlations vs (sG, sRho)
  if (hJet.isValid() && !jetIdx.empty()) {
    if (hasSG) {
      float bestDR2=1e9f, bestDPhi=1e9f;
      for (int idx : jetIdx) {
        const auto& j=hJet->at(idx);
        const float dr2 = deltaR2(sG.eta, sG.phi, toF(j.eta()), toF(j.phi()));
        if (dr2 < bestDR2) bestDR2=dr2;
        const float dphi = absDeltaPhi(sG.phi, toF(j.phi()));
        if (dphi < bestDPhi) bestDPhi=dphi;
      }
      if (scoutJetIncl_.h_min_dr2_g_j) scoutJetIncl_.h_min_dr2_g_j->Fill(bestDR2);
      if (scoutJetIncl_.h_min_dphi_g_j) scoutJetIncl_.h_min_dphi_g_j->Fill(bestDPhi);
      const auto& j1=hJet->at(jetIdx[0]);
      if (sG.pt>0.f && scoutJetIncl_.h_ptbal_j1_g) scoutJetIncl_.h_ptbal_j1_g->Fill(toF(j1.pt())/sG.pt);
    }
    if (hasSRho) {
      float bestDR2=1e9f, bestDPhi=1e9f;
      for (int idx : jetIdx) {
        const auto& j=hJet->at(idx);
        const float dr2 = deltaR2(sRho.eta(), sRho.phi(), toF(j.eta()), toF(j.phi()));
        if (dr2 < bestDR2) bestDR2=dr2;
        const float dphi = absDeltaPhi(sRho.phi(), toF(j.phi()));
        if (dphi < bestDPhi) bestDPhi=dphi;
      }
      if (scoutJetIncl_.h_min_dr2_rho_j) scoutJetIncl_.h_min_dr2_rho_j->Fill(bestDR2);
      if (scoutJetIncl_.h_min_dphi_rho_j) scoutJetIncl_.h_min_dphi_rho_j->Fill(bestDPhi);
      const auto& j1=hJet->at(jetIdx[0]);
      const float rhoPt=sRho.pt();
      if (rhoPt>0.f && scoutJetIncl_.h_ptbal_j1_rho) scoutJetIncl_.h_ptbal_j1_rho->Fill(toF(j1.pt())/rhoPt);
    }
  }

  // ----------------------------
  // 3) GEN <-> SCOUT jet matching (MC only)
  // ----------------------------
  if (storeGEN_ && doJetMatching_) {
    edm::Handle<reco::GenJetCollection> hGJ;
    ev.getByToken(genJetToken_, hGJ);
    if (hGJ.isValid() && hJet.isValid()) {
      for (const auto& gj : *hGJ) {
        const float gpt=toF(gj.pt()), geta=toF(gj.eta()), gphi=toF(gj.phi());
        if (gpt < toF(genJetMinPt30_)) continue;
        if (std::abs(geta) > toF(genJetMaxAbsEta_)) continue;
        if (jetMatch_.h_genjet_pt_den) jetMatch_.h_genjet_pt_den->Fill(gpt);

        int best=-1; float bestDR2=matchJetDR2_;
        for (int i=0;i<(int)hJet->size();++i) {
          const auto& sj=hJet->at(i);
          const float dr2=deltaR2(geta, gphi, toF(sj.eta()), toF(sj.phi()));
          if (dr2 < bestDR2) { bestDR2=dr2; best=i; }
        }
        if (best<0) continue;

        const auto& sj=hJet->at(best);
        const float spt=toF(sj.pt()), seta=toF(sj.eta());
        if (jetMatch_.h_genjet_pt_num) jetMatch_.h_genjet_pt_num->Fill(gpt);
        if (jetMatch_.h_dr2) jetMatch_.h_dr2->Fill(bestDR2);
        if (gpt>0.f && jetMatch_.h_resp_pt) jetMatch_.h_resp_pt->Fill(spt/gpt);
        if (gpt>0.f && jetMatch_.h_resp_pt_vs_eta) jetMatch_.h_resp_pt_vs_eta->Fill(seta, spt/gpt);

        const float sEMF = jetPHF(sj) + jetELF(sj);
        if (jetMatch_.h_emf) jetMatch_.h_emf->Fill(sEMF);
        if (gpt>0.f && jetMatch_.h_resp_pt_vs_emf) jetMatch_.h_resp_pt_vs_emf->Fill(sEMF, spt/gpt);
      }
    }
  }

  // ----------------------------
  // 4) Truth matching (photon + rho from tracks + pf-cands)
  // ----------------------------
  if (storeGEN_ && doTruthMatching_) {
    // Efficiency denominators
    if (hasG && matchH_.h_eff_g_den) matchH_.h_eff_g_den->Fill(g.pt);
    if (hasPiPi && matchH_.h_eff_rho_den) matchH_.h_eff_rho_den->Fill(rho.pt());
    if (f_hasG && matchH_.h_eff_g_den_fid) matchH_.h_eff_g_den_fid->Fill(f_g.pt);
    if (f_hasPiPi && matchH_.h_eff_rho_den_fid) matchH_.h_eff_rho_den_fid->Fill(f_rho.pt());

    // --- Match GEN gamma -> SCOUT photon
    bool matchedG=false;
    SimpleCand mG;
    if (hasG && hPho.isValid()) {
      int best=-1; float bestDR2=matchPhoDR2_;
      for (int i=0;i<(int)hPho->size();++i) {
        const auto& p=hPho->at(i);
        const float dr2 = deltaR2(g.eta, g.phi, toF(p.eta()), toF(p.phi()));
        if (dr2 < bestDR2) { bestDR2=dr2; best=i; }
      }
      if (matchH_.h_dr2_g && bestDR2 < 998.f) matchH_.h_dr2_g->Fill(bestDR2);
      if (best>=0) {
        matchedG=true;
        const auto& p=hPho->at(best);
        mG.pt=toF(p.pt()); mG.eta=toF(p.eta()); mG.phi=toF(p.phi()); mG.mass=0.f; mG.charge=0;
        scoutMatch_.fillPhoton(mG);
        if (matchH_.h_eff_g_num) matchH_.h_eff_g_num->Fill(g.pt);
        if (hasG && g.pt>0.f && matchH_.h_resp_g_pt) matchH_.h_resp_g_pt->Fill(mG.pt / g.pt);
        if (f_hasG && matchH_.h_eff_g_num_fid && passAbsEta(g.eta, fidPhoMaxAbsEta_)) matchH_.h_eff_g_num_fid->Fill(g.pt);
      }
    }

    // --- Match GEN pions -> SCOUT tracks (two independent best matches)
    bool matchedPiP=false, matchedPiM=false;
    Run3ScoutingTrack mTkP, mTkM; // only valid if flags true
    float dr2_p=999.f, dr2_m=999.f;

    auto matchPionToTrack = [&](const SimpleCand& genPi, int wantCharge, bool& ok, Run3ScoutingTrack& outTk, float& outDR2) {
      ok=false; outDR2=999.f;
      if (!hTk.isValid()) return;
      int best=-1; float bestDR2=matchTkDR2_;
      for (int i=0;i<(int)hTk->size();++i) {
        const auto& t=hTk->at(i);
        if (!passScoutTkQuality_(t)) continue;
        if (wantCharge!=0 && t.tk_charge()!=wantCharge) continue;
        const float dr2=deltaR2(genPi.eta, genPi.phi, toF(t.tk_eta()), toF(t.tk_phi()));
        if (dr2 < bestDR2) { bestDR2=dr2; best=i; }
      }
      outDR2 = bestDR2;
      if (best>=0) { ok=true; outTk = hTk->at(best); }
    };

    if (hasPiPi) {
      matchPionToTrack(rho.piPlus, +1, matchedPiP, mTkP, dr2_p);
      matchPionToTrack(rho.piMinus, -1, matchedPiM, mTkM, dr2_m);
      if (matchH_.h_dr2_piPlus && dr2_p < 998.f) matchH_.h_dr2_piPlus->Fill(dr2_p);
      if (matchH_.h_dr2_piMinus && dr2_m < 998.f) matchH_.h_dr2_piMinus->Fill(dr2_m);
    }

    bool matchedRho=false;
    RhoCand mRho;
    if (hasPiPi && matchedPiP && matchedPiM) {
      TLorentzVector vP, vM;
      setP4_pion(vP, toF(mTkP.tk_pt()), toF(mTkP.tk_eta()), toF(mTkP.tk_phi()));
      setP4_pion(vM, toF(mTkM.tk_pt()), toF(mTkM.tk_eta()), toF(mTkM.tk_phi()));
      TLorentzVector v = vP+vM;
      matchedRho=true;
      mRho.p4=v; mRho.mass=toF(v.M());
      mRho.piPlus = SimpleCand{toF(mTkP.tk_pt()), toF(mTkP.tk_eta()), toF(mTkP.tk_phi()), M_PI_CH, +1};
      mRho.piMinus= SimpleCand{toF(mTkM.tk_pt()), toF(mTkM.tk_eta()), toF(mTkM.tk_phi()), M_PI_CH, -1};
      scoutMatch_.fillRho(mRho);
      if (matchH_.h_eff_rho_num) matchH_.h_eff_rho_num->Fill(rho.pt());
      if (matchH_.h_resp_rho_m) matchH_.h_resp_rho_m->Fill(mRho.mass - rho.mass);
      // quality subset: both matched tracks already passed passScoutTkQuality_
      if (matchH_.h_resp_rho_m_q) matchH_.h_resp_rho_m_q->Fill(mRho.mass - rho.mass);

      if (f_hasPiPi && matchH_.h_eff_rho_num_fid && passAbsEta(rho.eta(), fidPiMaxAbsEta_) && passAbsEta(rho.piPlus.eta, fidPiMaxAbsEta_) && passAbsEta(rho.piMinus.eta, fidPiMaxAbsEta_)) {
        matchH_.h_eff_rho_num_fid->Fill(rho.pt());
      }
      if (hasSRho && matchH_.h_dr2_rho_algo_vs_match) {
        matchH_.h_dr2_rho_algo_vs_match->Fill(deltaR2(sRho.eta(), sRho.phi(), mRho.eta(), mRho.phi()));
      }
    }

    if (matchedG && matchedRho) {
      TLorentzVector vg; setP4_massless(vg, mG.pt, mG.eta, mG.phi);
      HCand mH; mH.gamma=mG; mH.rho=mRho; mH.p4 = vg + mRho.p4; mH.mass = toF(mH.p4.M());
      scoutMatch_.fillHcand(mH);
      if (hasHcand && matchH_.h_resp_hcand_m) matchH_.h_resp_hcand_m->Fill(mH.mass - hc.mass);
    }

    // --- Match GEN pions -> PF candidates (and fill dedicated matched-pair pack)
    if (hasPiPi && hPFC.isValid()) {
      int bestP=-1, bestM=-1;
      float bestDR2P=matchTkDR2_, bestDR2M=matchTkDR2_;
      for (int i=0;i<(int)hPFC->size();++i) {
        const auto& p=hPFC->at(i);
        if (pfPionOnly_ && std::abs(p.pdgId())!=211) continue;
        if (!passScoutPFQuality_(p)) continue;
        const int q = chargeFromPdgId_(p.pdgId());
        const float eta=pf_eta(p, pfUseTrkVars_), phi=pf_phi(p, pfUseTrkVars_);
        if (q>0) {
          const float dr2 = deltaR2(rho.piPlus.eta, rho.piPlus.phi, eta, phi);
          if (dr2 < bestDR2P) { bestDR2P=dr2; bestP=i; }
        } else if (q<0) {
          const float dr2 = deltaR2(rho.piMinus.eta, rho.piMinus.phi, eta, phi);
          if (dr2 < bestDR2M) { bestDR2M=dr2; bestM=i; }
        }
      }
      if (bestP>=0 && bestM>=0) {
        const auto& piP = hPFC->at(bestP);
        const auto& piM = hPFC->at(bestM);
        scoutPFMatch_.fillParticleInclusive(piP, pfUseTrkVars_);
        scoutPFMatch_.fillParticleInclusive(piM, pfUseTrkVars_);
        pfPairFromPFCMatch_.fill(piP, piM, pfUseTrkVars_);
      }
    }
  }

  // ----------------------------
  // 5) PF-based rho from ALL OS quality pion pairs (no truth matching)
  // ----------------------------
  const bool hasPFPhoton = hasSG;
  const SimpleCand& gReco = sG;

  int bestPF_i=-1, bestPF_j=-1;
  float bestScore=std::numeric_limits<float>::infinity();

  float bestHMass=-1.f, bestRhoMass=-1.f, bestPtBal=-1.f, bestDPhi=-1.f;
  (void)bestHMass; (void)bestRhoMass; (void)bestPtBal; (void)bestDPhi;

  if (hPFC.isValid()) {
    std::vector<int> piIdx;
    piIdx.reserve(hPFC->size());

    for (int i=0;i<(int)hPFC->size();++i) {
      const auto& p = hPFC->at(i);
      if (pfPionOnly_ && std::abs(p.pdgId())!=211) continue;
      if (!passScoutPFQuality_(p)) continue;
      piIdx.push_back(i);
    }

    for (int a=0;a<(int)piIdx.size();++a) {
      const auto& pa = hPFC->at(piIdx[a]);
      const int qa = chargeFromPdgId_(pa.pdgId());
      const float pta = pf_pt(pa, pfUseTrkVars_), etaa=pf_eta(pa, pfUseTrkVars_), phia=pf_phi(pa, pfUseTrkVars_);
      for (int b=a+1;b<(int)piIdx.size();++b) {
        const auto& pb = hPFC->at(piIdx[b]);
        const int qb = chargeFromPdgId_(pb.pdgId());
        if (qa*qb >= 0) continue;

        const float ptb = pf_pt(pb, pfUseTrkVars_), etab=pf_eta(pb, pfUseTrkVars_), phib=pf_phi(pb, pfUseTrkVars_);

        TLorentzVector vA, vB; setP4_pion(vA, pta, etaa, phia); setP4_pion(vB, ptb, etab, phib);
        const TLorentzVector vR = vA+vB;
        const float mR = toF(vR.M());
        const float ptR = toF(vR.Pt());
        const float dphiPP = absDeltaPhi(phia, phib);
        const float dr2PP = deltaR2(etaa, phia, etab, phib);

        // "all OS quality pairs" pack (already quality-filtered per-cand)
        if (pfAna_.h_rho_m_all) pfAna_.h_rho_m_all->Fill(mR);
        if (pfAna_.h_rho_pt_all) pfAna_.h_rho_pt_all->Fill(ptR);
        if (pfAna_.h_rho_dphi_all) pfAna_.h_rho_dphi_all->Fill(dphiPP);
        if (pfAna_.h_rho_dr2_all) pfAna_.h_rho_dr2_all->Fill(dr2PP);

        const bool sameV = (pa.vertex() == pb.vertex());
        if (pfAna_.h_pair_sameVtx_all) pfAna_.h_pair_sameVtx_all->Fill(sameV ? 1.0 : 0.0);
        if (pfAna_.h_pair_dz_diff_all) pfAna_.h_pair_dz_diff_all->Fill(std::abs(toF(pa.dz()) - toF(pb.dz())));
        if (pfAna_.h_pair_dxy_diff_all) pfAna_.h_pair_dxy_diff_all->Fill(std::abs(toF(pa.dxy()) - toF(pb.dxy())));

        // Candidate-level with photon (for all pairs if photon exists)
        if (hasPFPhoton) {
          TLorentzVector vG; setP4_massless(vG, gReco.pt, gReco.eta, gReco.phi);
          const TLorentzVector vH = vR + vG;
          const float mH = toF(vH.M());
          const float ptH = toF(vH.Pt());
          const float dphiGR = absDeltaPhi(gReco.phi, toF(vR.Phi()));
          const float ptbal = (gReco.pt > 0.f) ? (ptR / gReco.pt) : 0.f;

          if (pfAna_.h_hcand_m_all) pfAna_.h_hcand_m_all->Fill(mH);
          if (pfAna_.h_hcand_pt_all) pfAna_.h_hcand_pt_all->Fill(ptH);
          if (pfAna_.h_dphi_g_rho_all) pfAna_.h_dphi_g_rho_all->Fill(dphiGR);
          if (pfAna_.h_ptbal_rho_g_all) pfAna_.h_ptbal_rho_g_all->Fill(ptbal);

          // Vertex-quality cuts (pair-level)
          bool passVtx=true;
          if (pfRequireSameVtx_ && !sameV) passVtx=false;
          if (std::abs(toF(pa.dz()) - toF(pb.dz())) > toF(pfMaxAbsDzDiff_)) passVtx=false;
          if (std::abs(toF(pa.dxy()) - toF(pb.dxy())) > toF(pfMaxAbsDxyDiff_)) passVtx=false;

          if (passVtx) {
            if (pfAna_.h_rho_m_vtx) pfAna_.h_rho_m_vtx->Fill(mR);
            if (pfAna_.h_rho_pt_vtx) pfAna_.h_rho_pt_vtx->Fill(ptR);
            if (pfAna_.h_hcand_m_vtx) pfAna_.h_hcand_m_vtx->Fill(mH);

            // 3-body cuts
            bool pass3=true;
            if (ptR < toF(pfRhoMinPt_)) pass3=false;
            if (dphiGR < toF(pfMinAbsDPhiGRho_)) pass3=false;
            if (ptbal < toF(pfMinPtBal_) || ptbal > toF(pfMaxPtBal_)) pass3=false;
            if (pfRhoMassMax_ > 0.0) {
              if (mR < toF(pfRhoMassMin_) || mR > toF(pfRhoMassMax_)) pass3=false;
            }

            if (pass3) {
              if (pfAna_.h_rho_m_3body) pfAna_.h_rho_m_3body->Fill(mR);
              if (pfAna_.h_rho_pt_3body) pfAna_.h_rho_pt_3body->Fill(ptR);
              if (pfAna_.h_hcand_m_3body) pfAna_.h_hcand_m_3body->Fill(mH);
              if (pfAna_.h_hcand_pt_3body) pfAna_.h_hcand_pt_3body->Fill(ptH);

              // Best-per-event scoring (mass closeness dominates)
              const float pull_mH = (mH - M_H) / 10.0f;
              const float pull_mR = (mR - M_RHO) / 0.25f;
              const float pull_pt = (ptR - 60.0f) / 40.0f;
              const float score = pull_mH*pull_mH + 0.35f*pull_mR*pull_mR + 0.10f*pull_pt*pull_pt;

              if (score < bestScore) {
                bestScore = score;
                bestPF_i = piIdx[a];
                bestPF_j = piIdx[b];
                bestHMass = mH;
                bestRhoMass = mR;
                bestPtBal = ptbal;
                bestDPhi = dphiGR;
              }
            }
          }
        } // hasPFPhoton
      }
    }

    // Fill best-per-event histos (after 3-body cuts) if found
    if (bestPF_i >= 0 && bestPF_j >= 0 && hasPFPhoton) {
      const auto& pa = hPFC->at(bestPF_i);
      const auto& pb = hPFC->at(bestPF_j);

      const float pta = pf_pt(pa, pfUseTrkVars_), etaa=pf_eta(pa, pfUseTrkVars_), phia=pf_phi(pa, pfUseTrkVars_);
      const float ptb = pf_pt(pb, pfUseTrkVars_), etab=pf_eta(pb, pfUseTrkVars_), phib=pf_phi(pb, pfUseTrkVars_);

      TLorentzVector vA, vB; setP4_pion(vA, pta, etaa, phia); setP4_pion(vB, ptb, etab, phib);
      const TLorentzVector vR = vA+vB;

      TLorentzVector vG; setP4_massless(vG, gReco.pt, gReco.eta, gReco.phi);
      const TLorentzVector vH = vR + vG;

      const float mR = toF(vR.M());
      const float mH = toF(vH.M());
      const float ptbal = (gReco.pt > 0.f) ? (toF(vR.Pt()) / gReco.pt) : 0.f;
      const float dphiGR = absDeltaPhi(gReco.phi, toF(vR.Phi()));

      if (pfAna_.h_hcand_m_best) pfAna_.h_hcand_m_best->Fill(mH);
      if (pfAna_.h_rho_m_best) pfAna_.h_rho_m_best->Fill(mR);
      if (pfAna_.h_ptbal_rho_g_best) pfAna_.h_ptbal_rho_g_best->Fill(ptbal);
      if (pfAna_.h_dphi_g_rho_best) pfAna_.h_dphi_g_rho_best->Fill(dphiGR);
    }
  }

} // analyze

DEFINE_FWK_MODULE(ScoutingHiggsRho);